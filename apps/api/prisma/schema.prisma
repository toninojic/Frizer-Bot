generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  SALON_OWNER
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

enum BookingChannel {
  MANUAL
  PHONE
  WHATSAPP
  INSTAGRAM
}

enum ConversationChannel {
  MANUAL
  PHONE
  WHATSAPP
  INSTAGRAM
  WEB_CHAT
}

enum ConversationSessionStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  FAILED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ConversationState {
  START
  GREETING
  INTENT_DETECTION
  BOOKING_SERVICE
  BOOKING_WORKER
  BOOKING_DATE_TIME
  BOOKING_SLOT_CONFIRMATION
  BOOKING_CUSTOMER_NAME
  BOOKING_FINAL_CONFIRMATION
  BOOKING_COMPLETED
  CANCELLATION_LOOKUP
  CANCELLATION_CONFIRMATION
  CANCELLATION_COMPLETED
  RESCHEDULE_LOOKUP
  RESCHEDULE_DATE_TIME
  RESCHEDULE_SLOT_CONFIRMATION
  RESCHEDULE_COMPLETED
  TRANSFER_TO_HUMAN
  FALLBACK
  END
}

enum ConversationIntent {
  BOOK_APPOINTMENT
  CANCEL_APPOINTMENT
  RESCHEDULE_APPOINTMENT
  TALK_TO_HUMAN
  UNKNOWN
}

enum FeatureKey {
  MANUAL_BOOKING
  AI_RECEPTIONIST
  VOICE
  SMS
  WHATSAPP
  INSTAGRAM
  REMINDERS
  CALL_RECORDING
  CALL_TRANSCRIPTS
  ANALYTICS
}

enum CallOutcome {
  BOOKED
  CANCELLED
  TRANSFERRED
  FAILED
  INFO_ONLY
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Salon {
  id                       String            @id @default(cuid())
  name                     String
  phone                    String
  twilioPhoneNumber        String?           @unique @map("twilio_phone_number")
  city                     String?
  timezone                 String
  isActive                 Boolean           @default(true) @map("is_active")
  receptionistName         String?           @map("receptionist_name")
  receptionistEnabled      Boolean           @default(true) @map("receptionist_enabled")
  welcomeMessage           String?           @map("welcome_message")
  transferPhone            String?           @map("transfer_phone")
  workingAfterHoursEnabled Boolean           @default(false) @map("working_after_hours_enabled")
  smsConfirmationsEnabled  Boolean           @default(true) @map("sms_confirmations_enabled")
  reminderHoursBefore      Int               @default(2) @map("reminder_hours_before")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  users                    User[]
  workers                  Worker[]
  services                 Service[]
  workingHours             WorkingHour[]
  workerTimeBlocks         WorkerTimeBlock[]
  customers                Customer[]
  appointments             Appointment[]
  callLogs                 CallLog[]
  smsLogs                  SmsLog[]
  features                 SalonFeature[]
  toolExecutionLogs        ToolExecutionLog[]
  conversationSessions     ConversationSession[]

  @@map("salons")
}

model SalonFeature {
  id         String     @id @default(cuid())
  salonId    String     @map("salon_id")
  featureKey FeatureKey @map("feature_key")
  enabled    Boolean    @default(false)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  salon      Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, featureKey])
  @@index([salonId])
  @@map("salon_features")
}

model User {
  id           String   @id @default(cuid())
  salonId      String?  @map("salon_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(SALON_OWNER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  salon        Salon?   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("users")
}

model Worker {
  id           String            @id @default(cuid())
  salonId      String            @map("salon_id")
  name         String
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  salon        Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  timeBlocks   WorkerTimeBlock[]
  appointments Appointment[]

  @@index([salonId])
  @@map("workers")
}

model Service {
  id              String        @id @default(cuid())
  salonId         String        @map("salon_id")
  name            String
  durationMinutes Int           @map("duration_minutes")
  priceAmount     Decimal?      @map("price_amount") @db.Decimal(10, 2)
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  salon           Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([salonId])
  @@map("services")
}

model WorkingHour {
  id        String    @id @default(cuid())
  salonId   String    @map("salon_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  opensAt   String?   @map("opens_at") @db.VarChar(5)
  closesAt  String?   @map("closes_at") @db.VarChar(5)
  isClosed  Boolean   @default(false) @map("is_closed")
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, dayOfWeek])
  @@index([salonId])
  @@map("working_hours")
}

model WorkerTimeBlock {
  id        String   @id @default(cuid())
  salonId   String   @map("salon_id")
  workerId  String?  @map("worker_id")
  title     String
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  worker    Worker?  @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([workerId])
  @@map("worker_time_blocks")
}

model Customer {
  id           String        @id @default(cuid())
  salonId      String        @map("salon_id")
  name         String
  phone        String
  visitCount   Int           @default(0) @map("visit_count")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  smsLogs      SmsLog[]

  @@unique([salonId, phone])
  @@index([salonId])
  @@index([phone])
  @@map("customers")
}

model Appointment {
  id                    String            @id @default(cuid())
  salonId               String            @map("salon_id")
  workerId              String            @map("worker_id")
  customerId            String            @map("customer_id")
  serviceId             String            @map("service_id")
  customerNameSnapshot  String            @map("customer_name_snapshot")
  customerPhoneSnapshot String            @map("customer_phone_snapshot")
  serviceNameSnapshot   String            @map("service_name_snapshot")
  workerNameSnapshot    String            @map("worker_name_snapshot")
  startAt               DateTime          @map("start_at")
  endAt                 DateTime          @map("end_at")
  status                AppointmentStatus @default(BOOKED)
  channel               BookingChannel    @default(MANUAL)
  notes                 String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  salon                 Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  worker                Worker            @relation(fields: [workerId], references: [id])
  customer              Customer          @relation(fields: [customerId], references: [id])
  service               Service           @relation(fields: [serviceId], references: [id])
  smsLogs               SmsLog[]

  @@index([salonId])
  @@index([workerId])
  @@index([customerId])
  @@index([serviceId])
  @@index([startAt])
  @@index([endAt])
  @@index([status])
  @@index([channel])
  @@map("appointments")
}

model CallLog {
  id              String      @id @default(cuid())
  salonId         String      @map("salon_id")
  customerPhone   String?     @map("customer_phone")
  twilioCallSid   String?     @unique @map("twilio_call_sid")
  startedAt       DateTime    @map("started_at")
  endedAt         DateTime?   @map("ended_at")
  durationSeconds Int?        @map("duration_seconds")
  transcript      String?
  recordingUrl    String?     @map("recording_url")
  outcome         CallOutcome
  createdAt       DateTime    @default(now()) @map("created_at")
  salon           Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([startedAt])
  @@map("call_logs")
}

model SmsLog {
  id            String       @id @default(cuid())
  salonId       String       @map("salon_id")
  customerId    String?      @map("customer_id")
  appointmentId String?      @map("appointment_id")
  phone         String
  message       String
  status        SmsStatus    @default(PENDING)
  sentAt        DateTime?    @map("sent_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  salon         Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([customerId])
  @@index([appointmentId])
  @@map("sms_logs")
}

model ToolExecutionLog {
  id           String              @id @default(cuid())
  salonId      String              @map("salon_id")
  channel      ConversationChannel
  toolName     String              @map("tool_name")
  inputJson    Json                @map("input_json")
  outputJson   Json?               @map("output_json")
  success      Boolean
  errorCode    String?             @map("error_code")
  errorMessage String?             @map("error_message")
  createdAt    DateTime            @default(now()) @map("created_at")
  salon        Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([channel])
  @@index([toolName])
  @@index([createdAt])
  @@map("tool_execution_logs")
}

model ConversationSession {
  id                   String                    @id @default(cuid())
  salonId              String                    @map("salon_id")
  channel              ConversationChannel
  customerPhone        String?                   @map("customer_phone")
  twilioCallSid        String?                   @unique @map("twilio_call_sid")
  status               ConversationSessionStatus @default(ACTIVE)
  currentState         ConversationState         @default(START) @map("current_state")
  collectedData        Json                      @default("{}") @map("collected_data")
  lastUserMessage      String?                   @map("last_user_message")
  lastAssistantMessage String?                   @map("last_assistant_message")
  startedAt            DateTime                  @default(now()) @map("started_at")
  endedAt              DateTime?                 @map("ended_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  salon                Salon                     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  messages             ConversationMessage[]

  @@index([salonId])
  @@index([channel])
  @@index([status])
  @@index([currentState])
  @@index([createdAt])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id        String                  @id @default(cuid())
  sessionId String                  @map("session_id")
  role      ConversationMessageRole
  content   String
  metadata  Json?
  createdAt DateTime                @default(now()) @map("created_at")
  session   ConversationSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([role])
  @@index([createdAt])
  @@map("conversation_messages")
}
