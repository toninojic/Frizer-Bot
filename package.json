{
  "name": "ai-salon-receptionist",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,mobile -c cyan,magenta \"npm run dev:api\" \"npm run dev:mobile\"",
    "api:dev": "npm --workspace @ai-salon/api run start:dev",
    "start": "npm --workspace @ai-salon/mobile run start",
    "web": "npm --workspace @ai-salon/mobile run web",
    "dev:api": "npm --workspace @ai-salon/api run start:dev",
    "dev:mobile": "npm --workspace @ai-salon/mobile run start",
    "db:migrate": "npm --workspace @ai-salon/api run db:migrate",
    "db:generate": "npm --workspace @ai-salon/api run db:generate",
    "db:seed": "npm --workspace @ai-salon/api run db:seed",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "multer": "^2.2.0"
  }
}
